ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-11.8/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=gpconv_cuda -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/TH -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/THC -isystem /usr/local/cuda-11.8/include -isystem /home/danny/anaconda3/envs/pointcloud/include/python3.9 -D_GLIBCXX_USE_CXX11_ABI=0 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=gpconv_cuda -DTORCH_API_INCLUDE_EXTENSION_H -DPYBIND11_COMPILER_TYPE=\"_gcc\" -DPYBIND11_STDLIB=\"_libstdcpp\" -DPYBIND11_BUILD_ABI=\"_cxxabi1011\" -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/TH -isystem /home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/include/THC -isystem /usr/local/cuda-11.8/include -isystem /home/danny/anaconda3/envs/pointcloud/include/python3.9 -D_GLIBCXX_USE_CXX11_ABI=0 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
ldflags = -shared -L/home/danny/anaconda3/envs/pointcloud/lib/python3.9/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda-11.8/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags



rule link
  command = $cxx $in $ldflags -o $out

build operator.o: compile /home/danny/WJJ/point_cloud_jscc/model/libs/cuda_lib/src/gpu/operator.cpp
build assign_score_withk_gpu.cuda.o: cuda_compile /home/danny/WJJ/point_cloud_jscc/model/libs/cuda_lib/src/gpu/assign_score_withk_gpu.cu
build assign_score_withk_halfkernel_gpu.cuda.o: cuda_compile /home/danny/WJJ/point_cloud_jscc/model/libs/cuda_lib/src/gpu/assign_score_withk_halfkernel_gpu.cu



build gpconv_cuda.so: link operator.o assign_score_withk_gpu.cuda.o assign_score_withk_halfkernel_gpu.cuda.o

default gpconv_cuda.so
